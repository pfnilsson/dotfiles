#!/usr/bin/env bash

if [[ $# -ge 1 ]]; then
  selected=$1
else
  selected=$(fd -t d -d 1 -a . ~/Projects ~/.config 2>/dev/null | fzf) || exit 0
fi
[[ -n ${selected:-} ]] || exit 0

name=$(basename "$selected")
name=${name//./_}
name=${name//[!A-Za-z0-9_-]/_}

attach_session() {
  local sname=$1
  if [[ -n ${TMUX-} ]]; then
    tmux switch-client -t "=$sname":1
  else
    tmux select-window -t "=$sname":1
    exec tmux attach-session -t "=$sname"
  fi
}

create_session() {
  local sname=$1 dir=$2
  tmux new-session -s "$sname" -c "$dir" -d -n nvim
  tmux new-window  -t "=$sname":2 -c "$dir" -n terminal
  tmux send-keys   -t "=$sname":1 "nvim" C-m
}

if tmux has-session -t "=$name" 2>/dev/null; then
  # Session exists — offer to attach or create a worktree
  if git -C "$selected" rev-parse --is-inside-work-tree &>/dev/null; then
    action=$(printf "attach\nworktree" | fzf --prompt="Session '$name' exists > ") || exit 0
  else
    action="attach"
  fi

  if [[ $action == "worktree" ]]; then
    branch=$(git -C "$selected" branch -a --format='%(refname:short)' \
      | fzf --prompt="Branch > " --print-query | tail -1) || exit 0
    [[ -n ${branch:-} ]] || exit 0
    branch=${branch#origin/}

    wt_dir="$(dirname "$selected")/${name}-${branch}"
    wt_dir=${wt_dir//\/\//\/}

    if [[ ! -d "$wt_dir" ]]; then
      git -C "$selected" worktree add "$wt_dir" "$branch" 2>/dev/null \
        || git -C "$selected" worktree add -b "$branch" "$wt_dir" || exit 1
    fi

    wt_name="${name}-${branch}"
    wt_name=${wt_name//./_}
    wt_name=${wt_name//[!A-Za-z0-9_-]/_}

    if ! tmux has-session -t "=$wt_name" 2>/dev/null; then
      create_session "$wt_name" "$wt_dir"
    fi
    attach_session "$wt_name"
  else
    attach_session "$name"
  fi
else
  create_session "$name" "$selected"
  attach_session "$name"
fi

