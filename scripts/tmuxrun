#!/usr/bin/env bash

if [[ $# -ge 1 ]]; then
  selected=$1
else
  selected=$(fd -t d -d 1 -a . ~/Projects ~/.config 2>/dev/null | fzf) || exit 0
fi
[[ -n ${selected:-} ]] || exit 0

name=$(basename "$selected")
name=${name//./_}
name=${name//[!A-Za-z0-9_-]/_}

attach_session() {
  local sname=$1
  if [[ -n ${TMUX-} ]]; then
    tmux switch-client -t "=$sname":1
  else
    tmux select-window -t "=$sname":1
    exec tmux attach-session -t "=$sname"
  fi
}

create_session() {
  local sname=$1 dir=$2
  tmux new-session -s "$sname" -c "$dir" -d -n nvim
  tmux new-window  -t "=$sname":2 -c "$dir" -n terminal
  tmux send-keys   -t "=$sname":1 "nvim" C-m
}

sanitize_name() {
  local n=$1
  n=${n//./_}
  n=${n//[!A-Za-z0-9_-]/_}
  printf '%s' "$n"
}

bare_create_worktree() {
  local repo=$1 sname=$2
  local branch
  branch=$(git -C "$repo" branch -a --format='%(refname:short)' \
    | fzf --prompt="Branch > " --print-query | tail -1) || exit 0
  [[ -n ${branch:-} ]] || exit 0
  branch=${branch#origin/}

  local wt_dir="$repo/$branch"
  if [[ ! -d "$wt_dir" ]]; then
    git -C "$repo" worktree add "$wt_dir" "$branch" 2>/dev/null \
      || git -C "$repo" worktree add -b "$branch" "$wt_dir" || exit 1
  fi

  local wt_name
  wt_name="$(sanitize_name "${sname}-${branch}")"
  if ! tmux has-session -t "=$wt_name" 2>/dev/null; then
    create_session "$wt_name" "$wt_dir"
  fi
  attach_session "$wt_name"
}

if [[ -d "$selected/.bare" ]]; then
  # --- bare-clone worktree path ---
  wt_paths=()
  while IFS= read -r line; do
    wt_paths+=("$line")
  done < <(
    git -C "$selected" worktree list --porcelain \
      | awk '/^worktree /{print $2}' \
      | grep -v '\.bare$'
  )

  if [[ ${#wt_paths[@]} -eq 0 ]]; then
    echo "No worktrees found in bare repo" >&2
    exit 1
  elif [[ ${#wt_paths[@]} -eq 1 ]]; then
    wt_selected="${wt_paths[0]}"
  else
    wt_selected=$(printf '%s\n' "${wt_paths[@]}" \
      | while read -r p; do basename "$p"; done \
      | fzf --prompt="Worktree > ") || exit 0
    # resolve back to full path
    for p in "${wt_paths[@]}"; do
      if [[ "$(basename "$p")" == "$wt_selected" ]]; then
        wt_selected="$p"
        break
      fi
    done
  fi

  wt_dirname=$(basename "$wt_selected")
  sname="$(sanitize_name "${name}-${wt_dirname}")"

  if tmux has-session -t "=$sname" 2>/dev/null; then
    action=$(printf "attach\nworktree" | fzf --prompt="Session '$sname' exists > ") || exit 0
    if [[ $action == "worktree" ]]; then
      bare_create_worktree "$selected" "$name"
    else
      attach_session "$sname"
    fi
  else
    create_session "$sname" "$wt_selected"
    attach_session "$sname"
  fi

else
  # --- non-bare: attach or create ---
  if ! tmux has-session -t "=$name" 2>/dev/null; then
    create_session "$name" "$selected"
  fi
  attach_session "$name"
fi

